[{"findings":[{"scannerType":"axe","url":"https://cds.coinbase.com/","html":"<div aria-label=\"Current message: COI...\" class=\"grid-govvvpf relativ...\" style=\"--gridTemplateColumn...\" aria-live=\"polite\" role=\"button\" tabindex=\"0\">","problemShort":"interactive controls must not be nested","problemUrl":"https://dequeuniversity.com/rules/axe/4.11/nested-interactive?application=playwright","ruleId":"nested-interactive","solutionShort":"ensure interactive controls are not nested as they are not always announced by screen readers or can cause focus problems for assistive technologies","solutionLong":"Fix any of the following:\n  Using a negative tabindex on an element inside an interactive control does not prevent assistive technologies from focusing the element (even with aria-hidden=\"true\")","screenshotId":"d81f1098-2b3c-4a8e-9b9d-93f420802b58"}],"issue":{"state":"open","id":4220976984,"nodeId":"I_kwDONMcP2c77lv9Y","url":"https://github.com/coinbase/cds/issues/593","title":"Accessibility issue: Interactive controls must not be nested on /"}},{"findings":[{"scannerType":"axe","url":"https://cds.coinbase.com/","html":"<html lang=\"en\" dir=\"ltr\" class=\"docs-wrapper plugin-docs plugin-id-default docs-version-current docs-doc-page\" data-has-hydrated=\"false\" data-theme=\"light\" data-rh=\"lang,dir,class\">","problemShort":"page should contain a level-one heading","problemUrl":"https://dequeuniversity.com/rules/axe/4.11/page-has-heading-one?application=playwright","ruleId":"page-has-heading-one","solutionShort":"ensure that the page, or at least one of its frames contains a level-one heading","solutionLong":"Fix all of the following:\n  Page must have a level-one heading","screenshotId":"6e635ea6-bb38-4856-90f2-3e9f1ecde051"}],"issue":{"state":"open","id":4220977126,"nodeId":"I_kwDONMcP2c77lv_m","url":"https://github.com/coinbase/cds/issues/594","title":"Accessibility issue: Page should contain a level-one heading on /"}}]
