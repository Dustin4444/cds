{
  "name": "react18-compat-test",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/react18-compat-test",
  "projectType": "application",
  "tags": ["react18-compat"],
  "targets": {
    "dev": {
      "command": "vite dev"
    },
    "start": {
