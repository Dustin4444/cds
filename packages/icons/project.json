{
  "name": "icons",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/icons/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "dev",
      "configurations": {
        "dev": {
          "command": "rm -rf esm && babel ./src --out-dir esm --extensions .ts,.tsx,.js,.jsx --copy-files --no-copy-ignored"
        },
        "prod": {
          "commands": [
            "rm -rf esm && babel ./src --out-dir esm --extensions .ts,.tsx,.js,.jsx --copy-files --no-copy-ignored"
          ],
          "parallel": false
        }
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "dev",
      "configurations": {
        "dev": {
          "command": "tsc --build --pretty --verbose"
        },
        "prod": {
          "commands": [
            "tsc --build ./tsconfig.build.json --pretty --verbose",
            "prettier ./dts --write --loglevel warn"
          ],
          "parallel": false
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "sync-icons": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "projects": [
            "figma-api"
          ],
          "target": "build"
        }
      ],
      "options": {
        "command": "tsx ./scripts/sync-icons/index.ts",
        "cwd": "packages/icons"
      }
    },
    "sync-icon-code-connect": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx ./scripts/sync-icon-code-connect/index.ts",
        "cwd": "packages/icons"
      }
    }
  }
}
