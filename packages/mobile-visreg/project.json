{
  "name": "mobile-visreg",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/mobile-visreg/src",
  "projectType": "library",
  "targets": {
    "setup": {
      "command": "node ./src/setup.mjs",
      "options": {
        "cwd": "packages/mobile-visreg"
      }
    },
    "ios": {
      "command": "node ./src/run.mjs --appId com.anonymous.test-expo --scheme testexpo --platform ios --platform-suffix _ios",
      "options": {
        "cwd": "packages/mobile-visreg"
      }
    },
    "android": {
      "command": "node ./src/run.mjs --appId com.anonymous.testexpo --scheme testexpo --platform android --platform-suffix _android",
      "options": {
        "cwd": "packages/mobile-visreg"
      }
    },
    "upload": {
      "command": "node ./src/upload.mjs",
      "options": {
        "cwd": "packages/mobile-visreg"
      }
    }
  }
}
