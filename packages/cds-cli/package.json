{
  "name": "@coinbase/cds-cli",
  "version": "8.49.0",
  "description": "Coinbase Design System - CLI",
  "repository": {
    "type": "git",
    "url": "git@github.com:coinbase/cds.git",
    "directory": "packages/cds-cli"
  },
  "type": "module",
  "bin": {
    "cds": "./esm/cli.js",
    "cds-cli": "./esm/cli.js"
  },
  "main": "./esm/index.js",
  "types": "./dts/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    "./*": {
      "types": "./dts/*.d.ts",
      "default": "./esm/*.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dts",
    "esm",
    "CHANGELOG"
  ],
  "dependencies": {
    "@coinbase/cds-mcp-server": "workspace:^"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-typescript": "^7.27.1"
  }
}
